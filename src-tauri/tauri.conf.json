{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "prinvue",
  "version": "1.0.0",
  "identifier": "nti.te4.prinvue",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "prinvue",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "appimage",
      "msi",
      "exe",
      "nsis",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "deb": {
      "depends": [
        "webkit2gtk-4.1"
      ]
    },
    "rpm": {
      "license": "MIT"
    },
    "nsis": {
      "installerIcon": "icons/icon.ico",
      "headerImage": "icons/installer-header.bmp",
      "dialogImage": "icons/installer-dialog.bmp"
    },
    "dmg": {
      "background": "icons/dmg-background.tiff",
      "format": "Zstandard"
    }
  }
}
